# RenewFlow Environment Configuration
# Copy to .env and fill in values

# RenewFlow API URL (Fastify backend)
VITE_API_URL=https://api-production-dcc6.up.railway.app/api/v1

# Kitz Gateway URL (legacy — auth + tool calls)
VITE_GATEWAY_URL=http://localhost:4000

# Feature Flags
VITE_FEATURE_AI_CHAT=true
VITE_FEATURE_REWARDS=true
VITE_FEATURE_PO_MANAGEMENT=true
