# RenewFlow Environment Configuration
# Copy to .env and fill in values

# API Base URL (backend) — in dev, Vite proxy handles this automatically
VITE_API_BASE_URL=/api/v1

# Kitz Gateway URL (auth + tool calls)
VITE_GATEWAY_URL=http://localhost:4000

# Feature Flags
VITE_FEATURE_AI_CHAT=true
VITE_FEATURE_REWARDS=true
VITE_FEATURE_PO_MANAGEMENT=true
